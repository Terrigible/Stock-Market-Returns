{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/returns_dashboard.py",
            "console": "integratedTerminal",
            "env": {
                "DASH_DEBUG": "false",
                "DASH_HOT_RELOAD": "true"
            }
        },
        {
            "name": "Run without Debugging",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/returns_dashboard.py",
            "console": "integratedTerminal",
            "args": ["--mode", "production", "--verbose"],
            "env": {
                "DASH_HOT_RELOAD": "true"
            }
        },
        {
            "name": "Profile",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/profile_app.py",
            "console": "integratedTerminal",
            "env": { "DASH_HOT_RELOAD": "false" }
        }
    ]
}
